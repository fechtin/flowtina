APP_NAME=Flowtina
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DEFAULT_LANGUAGE=en

# SQLite by default. For PostgreSQL: postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:////opt/flowtina/database/app.db

# Generate strong random values in production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please-use-a-long-random-string
# Fernet key (optional). If empty, derived from JWT_SECRET.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

SCHEDULER_ENABLED=true
SCHEDULER_MAX_THREADS=2
